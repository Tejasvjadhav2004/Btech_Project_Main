# ──────────────────────────────────────────────────────────────────────────────
# .env.example  —  SAFE TO COMMIT. Copy to .env and fill in real values.
# NEVER put real credentials in this file.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# For cloud DB (Supabase, Railway, Neon), paste the connection string they give.
# For local:  postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/supplier_db
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/supplier_db

# ── LangChain / OpenAI ────────────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-3.5-turbo

# ── API Access Keys ───────────────────────────────────────────────────────────
# Generate keys: python3 -c "import secrets; print('key-' + secrets.token_hex(12))"
# Add one key per team member. Remove a key to revoke access.
# Leave empty to allow open access (local dev only).
APP_API_KEYS=key-member1-xxxxxxxxxxxxxxxxxxxxxxxx,key-member2-xxxxxxxxxxxxxxxxxxxxxxxx
