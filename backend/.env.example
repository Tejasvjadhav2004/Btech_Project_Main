# MongoDB Configuration (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_DATABASE_NAME=supply_chain_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Dashboard Configuration
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501

# Data Configuration
SUPPLY_CHAIN_DATA_PATH=data/raw/supply_chain_data.csv
FASHION_BOUTIQUE_DATA_PATH=data/raw/fashion_boutique_dataset.csv

# Monitoring Configuration
LOW_STOCK_THRESHOLD=20
REORDER_THRESHOLD=10

# Number of Warehouses and Stores to Generate
NUM_WAREHOUSES=5
NUM_STORES=8

# Warehouse Locations (comma-separated cities)
WAREHOUSE_CITIES=Mumbai,Delhi,Bangalore,Kolkata,Chennai

# Store Locations (comma-separated cities)
STORE_CITIES=Mumbai,Delhi,Bangalore,Kolkata,Chennai,Hyderabad,Pune,Ahmedabad
